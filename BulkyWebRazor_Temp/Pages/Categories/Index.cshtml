@page
@using BulkyWebRazor_Temp.Models
@model BulkyWebRazor_Temp.Pages.Categories.IndexModel
<div class="container">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">
                Category List
            </h2>
        </div>

        <div class="col-6 text-end">
            <a asp-Page="/Categories/Create"  class="btn btn-primary bg-gradient w-40 mb-2">
                <i class="bi bi-plus-square-dotted"></i>
                Create new Category
            </a>
        </div>
    </div>
    <table class="table table-bordered table-striped">

        <thead>
            <tr>
                <th>Category Name</th>

                <th>Display Order</th>
            </tr>
        </thead>
        <tbody>
            @foreach (Category obj in Model.CategoryList.OrderBy(u => u.DisplayOrder))
            {
            
                <input asp-for="@obj.Id" hidden />

                <tr>
                    <td>@obj.Name</td>
                    <td>@obj.DisplayOrder</td>
                    <td class="d-flex justify-content-end">

                        <div class="btn-group " role="group">
                            <a asp-page="/Categories/Edit" asp-route-id="@obj.Id" class="btn text-bg-info ">
                                <i class="bi bi-pencil-square"></i>Edit
                            </a>
                            <a asp-page="/Categories/Delete"  asp-route-id="@obj.Id" class="btn text-bg-danger ">
                                <i class="bi bi-trash3-fill"></i>Delete
                            </a>
                        </div>
                    </td>

                </tr>
            }
        </tbody>
    </table>
</div>