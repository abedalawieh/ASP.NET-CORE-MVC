@page
@model BulkyWebRazor_Temp.Pages.Categories.DeleteModel
<form method="post">
    <input asp-for="Category.Id" hidden />
    <div class="border p-3 mt-4">
        <div class="row pb-3">
            <h2 class="text-primary">Delete Category</h2>
        </div>
        <div class="mb-3">
            <label asp-for="Category.Name" class="m-1"></label>
            <input disabled required asp-for="Category.Name" class="form-control" type="text" />

            <div class="mb-3">
                <label asp-for="Category.DisplayOrder" class="m-1"></label>
                <input disabled required asp-for="Category.DisplayOrder" class="form-control " type="number" />

            </div>
            <button type="submit" class="btn btn-danger ">Delete </button>

            <a asp-page="/Categories/Index" class="btn btn-outline-secondary">Go Back</a>
        </div>
</form>
@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}