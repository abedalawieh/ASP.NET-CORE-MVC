@model Category;
<form method="post">
    <input asp-for="Id" hidden/>
    <div class="border p-3 mt-4">
        <div class="row pb-3">
            <h2 class="text-primary">Delete Category</h2>
        </div>
          <div class="mb-3">
            <label asp-for="Name" class="m-1"></label>
            <input disabled required asp-for="Name" class="form-control" type="text" />

            <div class="mb-3">
                <label asp-for="DisplayOrder" class="m-1"></label>
                <input disabled required asp-for="DisplayOrder" class="form-control " type="number" />

            </div>
            <button type="submit" class="btn btn-danger ">Delete </button>

            <a asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary">Go Back</a>
        </div>
</form>

