@model List<Product>
<div class="container">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">
                Product List
            </h2>
        </div>

        <div class="col-6 text-end">
            <a asp-controller="Product" asp-action="Upsert" class="btn btn-primary bg-gradient w-40 mb-2">
                <i class="bi bi-plus-square-dotted"></i>
                Create new Product
            </a>
        </div>
    </div>
<table id="tblData" class="table table-bordered table-striped" style="width:80%">

    <thead>
    <tr>
                <th>Title</th>

                <th>ISBN</th>
                <th>Author</th>
                <th>ListPrice</th>
              @*   <th>Price for 1-50</th>
                <th>Price for 50+</th>
                <th>Price for 100+</th> *@

                <th>Category</th>


        </tr>
    </thead>
    
    </table>

</div>
@section Scripts{
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.7/css/dataTables.dataTables.min.css" />

    <script src="~/js/product.js" >
  
           
    </script>
   
} 