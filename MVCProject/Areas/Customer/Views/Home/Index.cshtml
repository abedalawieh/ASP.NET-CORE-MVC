@model IEnumerable<Product>

<div class="row pb-3">

    @foreach (var product in Model)
    {
        <div class="col-lg-3 col-sm-6">

            <div class="row p-2">



                <div class="col-12 p-1">

                    <div class="card border-0 p-3 shadow border-top border-5 rounded">
                        
                        <img src="/images/product/37201724-c701-4caf-b98c-3bd76db65a84.png" class="card-img-top rounded" />
                        <div class="pl-1">

                            <p class="card-title h5 opacity-75 text-uppercase  text-center">@product.Title</p>
                            <p class="card-title text-warning text-center">by @product.Author</p>

                        </div>
                        <div class="pl-1">

                            <p class="text-dark h5 text-opacity-75 text-uppercase  text-center">List Price :<span class="text-decoration-line-through">@product.ListPrice</span></p>

                            <div class="pl-1">

                                <p class="text-dark h5 text-opacity-75 text-uppercase  text-center">As Low as :<span>@product.Price100</span></p>

                            </div>
                        </div>
                        <div>     
                      <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-primary bg-gradient border-0 form-control">

                           Details
                       </a>
                        
                        </div>

                    </div>

                </div>

            </div>



        </div>
    }


</div>