@model Category;
<form method="post">
    <div class="border p-3 mt-4">
        <div class="row pb-3">
            <h2 class="text-primary">Edit Category</h2>
        </div>
        @*         <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        *@        <div class="mb-3">
            <label asp-for="Name" class="m-1"></label>
            <input required asp-for="Name" class="form-control" type="text" />
            <span asp-validation-for="Name" class="text-danger"></span>

            <div class="mb-3">
                <label asp-for="DisplayOrder" class="m-1"></label>
                <input required asp-for="DisplayOrder" class="form-control " type="number" />
                <span asp-validation-for="DisplayOrder" class="text-danger"></span>

            </div>
            <button type="submit" class="btn text-bg-info ">Update </button>

            <a asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary">Go Back</a>
        </div>
</form>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}